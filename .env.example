# Bot Config
# ==============================================================================
# Supports the following properties for each bot object:
# - token (Required): Your Discord bot token.
# - enabled (Optional): Set to false to disable a bot without removing its token.
# - logChannel (Optional): Channel ID where detections for this bot will be logged.
# - name (Optional): Friendly name for your reference (shown in local logs).
# - isWhitelist (Optional): true = only scan allowedChannels, false = scan all except disallowed.
# - allowedChannels (Optional): Array of channel IDs to scan (Active if isWhitelist: true).
# - disallowedChannels (Optional): Array of channel IDs to skip (Active if isWhitelist: false).
# ==============================================================================
BOTS='[
  {
    "token": "TOKEN_1",
    "name": "Bot One",
    "enabled": true,
    "logChannel": "ID_1",
    "isWhitelist": true,
    "allowedChannels": ["CHANNEL_ID_1"],
    "disallowedChannels": []
  },
  {
    "token": "TOKEN_2",
    "name": "Bot Two",
    "enabled": false,
    "logChannel": "ID_2",
    "isWhitelist": false,
    "disallowedChannels": ["CHANNEL_ID_2"]
  }
]'


# comma separated list of banned words/phrases, not case sensitive. 
BANNED_WORDS="crypto casino,special promo code,withdrawl successful,free gift"

# whether to delete messages containing banned words
SHOULD_DELETE="true"

# whether to punish users for sending banned words (timeout duration)
SHOULD_PUNISH="true"

# duration of timeout for users who send banned words (e.g., 7d, 24h, 30m)
TIMEOUT_DURATION="7d"

# whether to scan messages from all users, including bots
SCAN_EVERYTHING="true"

# number of triggers before punishment action is taken
TRIGGERS_BEFORE_ACTION="1"

# whether to enable debug mode for detailed logging (true/false)
DEBUG="false"

# delay in milliseconds for mass message analysis (default 2000)
MASS_ANALYZER_DELAY="3000"

# maximum number of attachments to scan per message
MAX_ATTACHMENTS="5"

# Google Gemini API Key
GEMINI_API_KEY=""

# OCR.space API Key
OCR_SPACE_API_KEY=""

# Groq API Key
GROQ_API_KEY=""

# OCR Engine Order (comma separated: tesseract,ocrspace,gemini,groq)
# Engines will be tried in this order. To disable an engine, remove it from this list.
OCR_ENGINE_ORDER="groq,tesseract,ocrspace,gemini"

# Gemini Model to use
GEMINI_MODEL="gemini-2.5-flash-lite"

# Number of images that trigger Gemini fallback (default 4)
GEMINI_TRIGGER_COUNT="4"

# Groq Vision Model
GROQ_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"




